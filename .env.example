DATABASE_URL=sqlite:///./nudge.db

# Must match the browser's exact Origin (scheme + host + port). No trailing slash.
# For cookie auth, list every SPA URL (comma-separated). Not compatible with "*".
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional: regex full-match for previews, e.g. https://.*\\.vercel\\.app
# CORS_ORIGIN_REGEX=

OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# Higher for more varied suggestions (default 0.85); enrich stays at 0.2.
# OPENAI_SUGGESTION_TEMPERATURE=0.85

PORT=8000

# Auth — min 32 chars (python -c "import secrets; print(secrets.token_urlsafe(32))")
JWT_SECRET_KEY=
# JWT_ACCESS_EXPIRE_MINUTES=15
# JWT_REFRESH_EXPIRE_DAYS=7
# Local dev often: COOKIE_SECURE=false, COOKIE_SAMESITE=lax
# Production + SPA on another domain (e.g. nudgeweb.app → API on *.koyeb.app):
#   COOKIE_SECURE=true
#   COOKIE_SAMESITE=none
#   CORS_ORIGINS=https://nudgeweb.app,https://www.nudgeweb.app
# Do NOT set AUTH_COOKIE_DOMAIN to the SPA host if the API is on koyeb.app — leave unset.
# COOKIE_SECURE=false
# COOKIE_SAMESITE=lax
# AUTH_COOKIE_DOMAIN=.example.com
# Login, register, and refresh always include access_token + refresh_token in JSON (use Authorization: Bearer when cookies fail, e.g. Safari / ITP).
# Log 401 reasons on task routes to stderr (visible in Koyeb / platform logs). No token values logged.
# AUTH_LOG_DENIALS=true

# Twilio — US toll-free / some numbers must be verified in Twilio Console before outbound SMS works:
# https://www.twilio.com/docs/messaging/compliance/toll-free/console-onboarding
# In-app: user verifies phone via POST /auth/me/phone/send-verification-code then /auth/me/phone/verify
#
# Recommended for phone verification: create a Verify Service and set (uses Twilio Verify API, not custom SMS bodies):
# TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SMS_OTP_EXPIRE_MINUTES=10
# SMS_OTP_MAX_SENDS_PER_HOUR=5
# SMS_OTP_COOLDOWN_SECONDS=45

# Twilio — daily SMS check-in (webhook: POST /webhooks/twilio/sms)
# Authenticated “send me a test SMS”: POST /auth/me/sms/test (session cookie or Bearer)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# Prefer a Messaging Service SID once toll-free is verified and attached there (omit TWILIO_PHONE_NUMBER if you use this):
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Or send From a specific number (E.164):
# TWILIO_PHONE_NUMBER=+15551234567
# Optional: SCHEDULER_SECRET for POST /internal/sms/run-daily-prompts (header X-Scheduler-Secret)
# SCHEDULER_SECRET=
# SMS_DRY_RUN=true
# SMS_USE_APSCHEDULER=true
# SMS_SCHEDULER_INTERVAL_MINUTES=2
# SMS_CHECKIN_HOUR_LOCAL=17
# SMS_CHECKIN_END_MINUTE=20
# SMS_CHECKIN_MAX_BODY_CHARS=900
